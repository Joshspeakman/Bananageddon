<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Monkey Maddness</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <div id="game-container">
    <canvas id="gameCanvas" width="640" height="480"></canvas>

    <!-- Title Screen -->
    <div id="title-screen" class="screen active">
      <div class="title-text">MONKEY MADDNESS</div>
      <div class="subtitle">Press Enter to Start</div>
    </div>

    <!-- Setup Screen -->
    <div id="setup-screen" class="screen">
      <div class="setup-box">
        <h2>GAME SETUP</h2>
        <div class="setup-field">
          <label for="player-name">Your Name:</label>
          <input type="text" id="player-name" maxlength="20" value="Player" autocomplete="off">
        </div>
        <div class="setup-field">
          <label for="rounds-to-win">Rounds to Win:</label>
          <input type="number" id="rounds-to-win" min="1" max="99" value="3">
        </div>
        <div class="setup-field">
          <label for="gravity-select">Gravity:</label>
          <select id="gravity-select">
            <option value="0.5">Moon (1.6 m/s²)</option>
            <option value="0.8">Mars (3.7 m/s²)</option>
            <option value="1" selected>Earth (9.8 m/s²)</option>
            <option value="1.5">Super (14.7 m/s²)</option>
            <option value="2.5">Jupiter (24.5 m/s²)</option>
          </select>
        </div>
        <div class="setup-field">
          <label for="explosive-select">Explosive Power:</label>
          <select id="explosive-select">
            <option value="15">Firecracker</option>
            <option value="30" selected>Standard</option>
            <option value="50">C4</option>
            <option value="80">Nuke</option>
          </select>
        </div>
        <div class="setup-field">
          <label for="timeofday-select">Time of Day:</label>
          <select id="timeofday-select">
            <option value="day" selected>Day</option>
            <option value="sunset">Sunset</option>
            <option value="night">Night</option>
          </select>
        </div>
        <div class="setup-hint">Press Enter to connect</div>
        <div id="setup-host-note" class="setup-host-note" style="display:none;">Settings are controlled by the host</div>
      </div>
    </div>

    <!-- Waiting Screen -->
    <div id="waiting-screen" class="screen">
      <div class="waiting-box">
        <h2>WAITING FOR OPPONENT</h2>
        <div id="waiting-url" class="waiting-url"></div>
        <div id="waiting-status" class="waiting-status">Share the URL above with Player 2</div>
      </div>
    </div>

    <!-- HUD overlay -->
    <div id="hud" class="screen">
      <div id="hud-p1" class="hud-score hud-left"></div>
      <div id="hud-p2" class="hud-score hud-right"></div>
      <div id="hud-turn" class="hud-turn"></div>
      <div id="hud-wind" class="hud-wind"></div>

      <!-- Input panel -->
      <div id="input-panel" class="input-panel" style="display:none;">
        <div class="input-row">
          <label for="input-angle">Angle:</label>
          <input type="number" id="input-angle" min="0" max="90" value="45" autocomplete="off">
        </div>
        <div class="input-row">
          <label for="input-velocity">Velocity:</label>
          <input type="number" id="input-velocity" min="0" max="200" value="50" autocomplete="off">
        </div>
        <button id="fire-btn" class="fire-btn">FIRE!</button>
      </div>
    </div>

    <!-- Match Over Screen -->
    <div id="match-over-screen" class="screen">
      <div class="match-over-box">
        <h1 id="winner-text"></h1>
        <div id="final-scores"></div>
        <div class="match-over-hint">Press R for rematch &bull; Esc for title</div>
      </div>
    </div>

    <!-- Pause overlay -->
    <div id="pause-screen" class="screen">
      <div class="pause-box">
        <h2>PAUSED</h2>
        <div>Press P or Esc to resume</div>
      </div>
    </div>

    <!-- Disconnect overlay -->
    <div id="disconnect-screen" class="screen">
      <div class="disconnect-box">
        <h2>OPPONENT DISCONNECTED</h2>
        <div>Waiting 60 seconds for reconnect...</div>
      </div>
    </div>

    <!-- Confirm overlay -->
    <div id="confirm-screen" class="screen">
      <div class="confirm-box">
        <h2>RESTART MATCH?</h2>
        <div class="confirm-buttons">
          <button id="confirm-yes" class="confirm-btn">Yes (Y)</button>
          <button id="confirm-no" class="confirm-btn">No (N)</button>
        </div>
      </div>
    </div>
  </div>

  <script src="net.js"></script>
  <script src="game.js"></script>
</body>
</html>
