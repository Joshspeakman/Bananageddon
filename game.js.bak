// Monkey Maddness — Client game engine (game.js)
// Handles rendering, sprites, audio, input, and game state display.
// All network communication goes through Net (net.js).

(function () {
  'use strict';

  // ─── Constants ──────────────────────────────────────────────────────────────
  const LOGICAL_W = 640;
  const LOGICAL_H = 480;
  const GORILLA_W = 28;
  const GORILLA_H = 28;
  const SUN_X = LOGICAL_W / 2;
  const SUN_Y = 40;
  const SUN_RADIUS = 30;

  // Colors (CGA/EGA palette) — sky color varies by timeOfDay
  const SKY_COLORS = {
    day: '#0000AA',
    sunset: '#AA4400',
    night: '#000022',
  };
  const STAR_COLOR = '#FFFFFF';
  let skyColor = '#0000AA';
  const BUILDING_COLORS = ['#55FFFF', '#FF55FF', '#AAAAAA'];
  const WINDOW_LIT = '#FFFF55';
  const WINDOW_UNLIT = '#555555';
  const GORILLA_COLOR = '#8B5A2B';
  const GORILLA_DARK = '#5C3317';
  const BANANA_COLOR = '#FFFF55';
  const SUN_COLOR = '#FFFF55';
  const TEXT_COLOR = '#FFFFFF';

  // ─── Canvas setup ──────────────────────────────────────────────────────────
  const canvas = document.getElementById('gameCanvas');
  const ctx = canvas.getContext('2d');
  ctx.imageSmoothingEnabled = false;

  // Offscreen terrain canvas
  const terrainCanvas = document.createElement('canvas');
  terrainCanvas.width = LOGICAL_W;
  terrainCanvas.height = LOGICAL_H;
  const terrainCtx = terrainCanvas.getContext('2d');
  terrainCtx.imageSmoothingEnabled = false;

  // Scale canvas to fit window
  function resizeCanvas() {
    const container = document.getElementById('game-container');
    const cw = container.clientWidth;
    const ch = container.clientHeight;
    const scale = Math.min(cw / LOGICAL_W, ch / LOGICAL_H);
    canvas.style.width = Math.floor(LOGICAL_W * scale) + 'px';
    canvas.style.height = Math.floor(LOGICAL_H * scale) + 'px';
  }
  window.addEventListener('resize', resizeCanvas);
  resizeCanvas();

  // ─── Seeded PRNG (mulberry32, must match server) ───────────────────────────
  function mulberry32(seed) {
    return function () {
      seed |= 0;
      seed = (seed + 0x6D2B79F5) | 0;
      let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  // ─── Game State ─────────────────────────────────────────────────────────────
  let gameState = 'title'; // title | setup | waiting | playing | matchOver | paused
  let previousState = null; // for pause resume
  let myPlayer = 0;    // 1 or 2 (0 = not assigned yet)
  let myName = 'Player';
  let opponentName = '';
  let roundsToWin = 3;
  let gravityMultiplier = 1;
  let explosionRadius = 30;
  let timeOfDay = 'day'; // day | sunset | night
  let scores = [0, 0];
  let playerNames = ['Player 1', 'Player 2'];
  let currentPlayer = 1;
  let wind = 0;

  // City
  let buildings = [];
  let citySeed = 0;

  // Gorillas
  let gorillas = [{ x: 0, y: 0 }, { x: 0, y: 0 }];
  let gorillaAnim = [0, 0]; // 0=idle, 1=right arm, 2=left arm, 3=both up, 4=both down (victory)
  let victoryDanceTimer = null;

  // Banana
  let banana = null; // {x, y, frame, trail:[]}
  let bananaTrail = [];
  let previousTrail = [];
  let showBanana = false;

  // Explosion
  let explosions = []; // [{x, y, radius, progress, maxRadius}] active animations
  let carvedExplosions = []; // [{x, y, radius}] all carved points

  // Sun
  let sunSurprised = false;
  let sunSurpriseTimer = null;

  // Window twinkles
  let twinkleWindows = []; // [{x, y, alpha, speed}]

  // Screen shake
  let shakeOffset = { x: 0, y: 0 };
  let shakeTimer = null;

  // Session token for reconnect auth
  let sessionToken = null;

  // ─── Audio (Web Audio API) ─────────────────────────────────────────────────
  let audioCtx = null;
  function ensureAudio() {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    }
    return audioCtx;
  }

  function playThrowSound() {
    const ctx = ensureAudio();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = 'square';
    osc.frequency.setValueAtTime(200, ctx.currentTime);
    osc.frequency.linearRampToValueAtTime(400, ctx.currentTime + 0.1);
    gain.gain.setValueAtTime(0.15, ctx.currentTime);
    gain.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.1);
    osc.connect(gain).connect(ctx.destination);
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + 0.1);
  }

  function playExplosionSound() {
    const ctx = ensureAudio();
    const bufferSize = ctx.sampleRate * 0.3;
    const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) {
      data[i] = (Math.random() * 2 - 1) * (1 - i / bufferSize);
    }
    const source = ctx.createBufferSource();
    source.buffer = buffer;
    const filter = ctx.createBiquadFilter();
    filter.type = 'lowpass';
    filter.frequency.setValueAtTime(2000, ctx.currentTime);
    filter.frequency.linearRampToValueAtTime(200, ctx.currentTime + 0.3);
    const gain = ctx.createGain();
    gain.gain.setValueAtTime(0.3, ctx.currentTime);
    gain.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.3);
    source.connect(filter).connect(gain).connect(ctx.destination);
    source.start(ctx.currentTime);
  }

  function playGorillaHitSound() {
    playExplosionSound();
    const ctx = ensureAudio();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = 'square';
    osc.frequency.setValueAtTime(400, ctx.currentTime + 0.1);
    osc.frequency.linearRampToValueAtTime(100, ctx.currentTime + 0.5);
    gain.gain.setValueAtTime(0.12, ctx.currentTime + 0.1);
    gain.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.5);
    osc.connect(gain).connect(ctx.destination);
    osc.start(ctx.currentTime + 0.1);
    osc.stop(ctx.currentTime + 0.5);
  }

  function playSunHitSound() {
    const ctx = ensureAudio();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = 'triangle';
    osc.frequency.setValueAtTime(1200, ctx.currentTime);
    gain.gain.setValueAtTime(0.1, ctx.currentTime);
    gain.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.08);
    osc.connect(gain).connect(ctx.destination);
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + 0.08);
  }

  let victoryAudioTimer = null;
  function playVictorySound() {
    const ctx = ensureAudio();
    // Ascending major triad beeps
    const notes = [523, 659, 784]; // C5, E5, G5
    let i = 0;
    victoryAudioTimer = setInterval(() => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'square';
      osc.frequency.setValueAtTime(notes[i % notes.length], ctx.currentTime);
      gain.gain.setValueAtTime(0.08, ctx.currentTime);
      gain.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.1);
      osc.connect(gain).connect(ctx.destination);
      osc.start(ctx.currentTime);
      osc.stop(ctx.currentTime + 0.1);
      i++;
    }, 125);
  }

  function stopVictorySound() {
    if (victoryAudioTimer) {
      clearInterval(victoryAudioTimer);
      victoryAudioTimer = null;
    }
  }

  function playUIConfirm() {
    const ctx = ensureAudio();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = 'square';
    osc.frequency.setValueAtTime(800, ctx.currentTime);
    gain.gain.setValueAtTime(0.06, ctx.currentTime);
    gain.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.05);
    osc.connect(gain).connect(ctx.destination);
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + 0.05);
  }

  // ─── City generation (must match server exactly) ───────────────────────────
  function generateCity(seed) {
    const rng = mulberry32(seed);
    const numBuildings = Math.floor(rng() * 5) + 8;
    const blds = [];
    let x = 0;
    const buildingWidth = LOGICAL_W / numBuildings;

    for (let i = 0; i < numBuildings; i++) {
      const w = Math.floor(buildingWidth);
      const h = Math.floor(rng() * 200) + 80;
      const color = BUILDING_COLORS[Math.floor(rng() * BUILDING_COLORS.length)];
      blds.push({ x, w, h, y: LOGICAL_H - h, color });
      x += w;
    }
    return blds;
  }

  // ─── Drawing functions ────────────────────────────────────────────────────

  // Stars (generated once per round for night/sunset)
  let stars = [];
  function generateStars() {
    stars = [];
    if (timeOfDay === 'night' || timeOfDay === 'sunset') {
      const count = timeOfDay === 'night' ? 120 : 40;
      for (let i = 0; i < count; i++) {
        stars.push({
          x: Math.random() * LOGICAL_W,
          y: Math.random() * (LOGICAL_H * 0.5),
          brightness: 0.3 + Math.random() * 0.7,
          twinkleSpeed: 1 + Math.random() * 3,
          phase: Math.random() * Math.PI * 2,
        });
      }
    }
  }

  function drawSky() {
    skyColor = SKY_COLORS[timeOfDay] || SKY_COLORS.day;

    if (timeOfDay === 'sunset') {
      // Gradient sky for sunset
      const grad = ctx.createLinearGradient(0, 0, 0, LOGICAL_H);
      grad.addColorStop(0, '#220044');
      grad.addColorStop(0.3, '#AA4400');
      grad.addColorStop(0.6, '#FF6622');
      grad.addColorStop(1, '#AA2200');
      ctx.fillStyle = grad;
    } else {
      ctx.fillStyle = skyColor;
    }
    ctx.fillRect(0, 0, LOGICAL_W, LOGICAL_H);

    // Draw stars for night/sunset
    if (stars.length > 0) {
      const t = performance.now() / 1000;
      for (const s of stars) {
        const flicker = 0.5 + 0.5 * Math.sin(t * s.twinkleSpeed + s.phase);
        const alpha = s.brightness * flicker;
        ctx.fillStyle = `rgba(255, 255, 255, ${alpha.toFixed(2)})`;
        ctx.fillRect(Math.floor(s.x), Math.floor(s.y), 2, 2);
      }
    }
  }

  function drawSun() {
    // Night: draw moon instead; Sunset: draw low orange sun
    const cx = SUN_X;
    const r = 18;

    if (timeOfDay === 'night') {
      // Moon
      const cy = SUN_Y;
      ctx.fillStyle = '#CCCCCC';
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.fill();
      // Moon shadow (crescent)
      ctx.fillStyle = SKY_COLORS.night;
      ctx.beginPath();
      ctx.arc(cx + 8, cy - 2, r - 2, 0, Math.PI * 2);
      ctx.fill();
      return;
    }

    // Sunset: sun sits lower and is orange
    const cy = timeOfDay === 'sunset' ? LOGICAL_H * 0.45 : SUN_Y;
    const sunColor = timeOfDay === 'sunset' ? '#FF6622' : SUN_COLOR;

    // Sun body
    ctx.fillStyle = sunColor;
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, Math.PI * 2);
    ctx.fill();

    // Rays
    for (let i = 0; i < 8; i++) {
      const angle = (i / 8) * Math.PI * 2;
      const x1 = cx + Math.cos(angle) * (r + 2);
      const y1 = cy + Math.sin(angle) * (r + 2);
      const x2 = cx + Math.cos(angle) * (r + 8);
      const y2 = cy + Math.sin(angle) * (r + 8);
      ctx.strokeStyle = sunColor;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(x2, y2);
      ctx.stroke();
    }

    // Face
    ctx.fillStyle = '#000000';
    if (sunSurprised) {
      // Surprised face: O mouth
      ctx.fillRect(cx - 4, cy - 4, 3, 3); // left eye
      ctx.fillRect(cx + 2, cy - 4, 3, 3); // right eye
      ctx.beginPath();
      ctx.arc(cx, cy + 5, 4, 0, Math.PI * 2);
      ctx.stroke();
    } else {
      // Normal face: dot eyes only
      ctx.fillRect(cx - 4, cy - 4, 3, 3); // left eye
      ctx.fillRect(cx + 2, cy - 4, 3, 3); // right eye
    }
  }

  function drawBuildings() {
    // Draw terrain canvas onto main canvas
    ctx.drawImage(terrainCanvas, 0, 0);
    // Draw twinkles over lit windows
    drawTwinkles();
  }

  function initTwinkles() {
    twinkleWindows = [];
    for (const b of buildings) {
      const rng = mulberry32(citySeed + b.x * 1000 + b.y);
      const winW = 4, winH = 4, gap = 2, padX = 4, padY = 4;
      for (let wy = b.y + padY; wy < LOGICAL_H - winH - gap; wy += winH + gap) {
        for (let wx = b.x + padX; wx < b.x + b.w - winW - padX; wx += winW + gap) {
          const isLit = rng() > 0.4;
          if (isLit && Math.random() < 0.15) {
            twinkleWindows.push({
              x: wx, y: wy, w: winW, h: winH,
              phase: Math.random() * Math.PI * 2,
              speed: 1.5 + Math.random() * 3,
            });
          }
        }
      }
    }
  }

  function drawTwinkles() {
    const now = performance.now() / 1000;
    for (const tw of twinkleWindows) {
      const glow = 0.3 + 0.7 * ((Math.sin(now * tw.speed + tw.phase) + 1) / 2);
      ctx.fillStyle = `rgba(255, 255, 255, ${(glow * 0.45).toFixed(2)})`;
      ctx.fillRect(tw.x, tw.y, tw.w, tw.h);
    }
  }

  function buildTerrainCanvas() {
    terrainCtx.clearRect(0, 0, LOGICAL_W, LOGICAL_H);

    for (const b of buildings) {
      terrainCtx.fillStyle = b.color;
      terrainCtx.fillRect(b.x, b.y, b.w, LOGICAL_H - b.y);

      // Windows
      const rng = mulberry32(citySeed + b.x * 1000 + b.y);
      const winW = 4;
      const winH = 4;
      const gap = 2;
      const padX = 4;
      const padY = 4;
      for (let wy = b.y + padY; wy < LOGICAL_H - winH - gap; wy += winH + gap) {
        for (let wx = b.x + padX; wx < b.x + b.w - winW - padX; wx += winW + gap) {
          terrainCtx.fillStyle = rng() > 0.4 ? WINDOW_LIT : WINDOW_UNLIT;
          terrainCtx.fillRect(wx, wy, winW, winH);
        }
      }
    }

    // Re-carve any explosions
    for (const exp of carvedExplosions) {
      carveExplosion(exp.x, exp.y, exp.radius);
    }
  }

  function carveExplosion(x, y, radius) {
    terrainCtx.save();
    terrainCtx.globalCompositeOperation = 'destination-out';
    terrainCtx.beginPath();
    terrainCtx.arc(x, y, radius, 0, Math.PI * 2);
    terrainCtx.fill();
    terrainCtx.restore();
  }

  // ─── Gorilla sprite ────────────────────────────────────────────────────────
  function drawGorilla(x, y, pose) {
    // pose: 0=idle, 1=right arm up, 2=left arm up, 3=both up, 4=both down
    const cx = x + GORILLA_W / 2;
    const cy = y + GORILLA_H / 2;

    // Body
    ctx.fillStyle = GORILLA_COLOR;
    ctx.fillRect(cx - 8, cy - 6, 16, 14); // torso

    // Head
    ctx.fillRect(cx - 6, cy - 12, 12, 8);

    // Face details
    ctx.fillStyle = GORILLA_DARK;
    ctx.fillRect(cx - 3, cy - 9, 2, 2); // left eye
    ctx.fillRect(cx + 1, cy - 9, 2, 2); // right eye
    ctx.fillRect(cx - 2, cy - 6, 4, 2); // mouth

    // Legs
    ctx.fillStyle = GORILLA_COLOR;
    ctx.fillRect(cx - 6, cy + 8, 5, 6);  // left leg
    ctx.fillRect(cx + 1, cy + 8, 5, 6);  // right leg

    // Arms based on pose
    ctx.fillStyle = GORILLA_COLOR;
    switch (pose) {
      case 0: // idle - arms at sides
        ctx.fillRect(cx - 12, cy - 4, 4, 12); // left arm
        ctx.fillRect(cx + 8, cy - 4, 4, 12);  // right arm
        break;
      case 1: // right arm raised
        ctx.fillRect(cx - 12, cy - 4, 4, 12); // left arm down
        ctx.fillRect(cx + 8, cy - 14, 4, 12); // right arm up
        break;
      case 2: // left arm raised
        ctx.fillRect(cx - 12, cy - 14, 4, 12); // left arm up
        ctx.fillRect(cx + 8, cy - 4, 4, 12);   // right arm down
        break;
      case 3: // both arms up
        ctx.fillRect(cx - 12, cy - 14, 4, 12);
        ctx.fillRect(cx + 8, cy - 14, 4, 12);
        break;
      case 4: // both arms down (for victory dance alternation)
        ctx.fillRect(cx - 12, cy - 2, 4, 12);
        ctx.fillRect(cx + 8, cy - 2, 4, 12);
        break;
    }
  }

  // ─── Banana sprite ─────────────────────────────────────────────────────────
  function drawBanana(x, y, frame) {
    ctx.fillStyle = BANANA_COLOR;
    const s = 4; // half-size
    switch (frame % 4) {
      case 0: // horizontal
        ctx.fillRect(x - s, y - 2, s * 2, 4);
        break;
      case 1: // diagonal /
        ctx.save();
        ctx.translate(x, y);
        ctx.rotate(-Math.PI / 4);
        ctx.fillRect(-s, -2, s * 2, 4);
        ctx.restore();
        break;
      case 2: // vertical
        ctx.fillRect(x - 2, y - s, 4, s * 2);
        break;
      case 3: // diagonal \ 
        ctx.save();
        ctx.translate(x, y);
        ctx.rotate(Math.PI / 4);
        ctx.fillRect(-s, -2, s * 2, 4);
        ctx.restore();
        break;
    }
  }

  // ─── Banana trail ──────────────────────────────────────────────────────────
  function drawTrail(trail, alpha) {
    if (trail.length < 2) return;
    ctx.fillStyle = `rgba(255, 255, 85, ${alpha})`;
    for (let i = 0; i < trail.length; i++) {
      if (i % 3 === 0) {
        ctx.fillRect(Math.floor(trail[i].x) - 1, Math.floor(trail[i].y) - 1, 2, 2);
      }
    }
  }

  // ─── Explosion animation ──────────────────────────────────────────────────
  function drawExplosions() {
    for (let i = explosions.length - 1; i >= 0; i--) {
      const exp = explosions[i];
      exp.progress += 1 / 60;

      let r, alpha;
      if (exp.progress < 0.15) {
        // Expanding phase
        r = (exp.progress / 0.15) * exp.maxRadius;
        alpha = 1;
      } else if (exp.progress < 0.40) {
        // Fading phase
        r = exp.maxRadius;
        alpha = 1 - (exp.progress - 0.15) / 0.25;
      } else {
        explosions.splice(i, 1);
        continue;
      }

      ctx.globalAlpha = alpha;
      ctx.fillStyle = BANANA_COLOR;
      ctx.beginPath();
      ctx.arc(exp.x, exp.y, r, 0, Math.PI * 2);
      ctx.fill();

      // Outer ring
      ctx.strokeStyle = '#FF5500';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.arc(exp.x, exp.y, r, 0, Math.PI * 2);
      ctx.stroke();

      ctx.globalAlpha = 1;
    }
  }

  // ─── Wind arrow ────────────────────────────────────────────────────────────
  function drawWindArrow() {
    const hudWind = document.getElementById('hud-wind');
    if (Math.abs(wind) < 0.5) {
      hudWind.textContent = 'Wind: calm';
      return;
    }
    const dir = wind > 0 ? '→' : '←';
    const bars = Math.min(10, Math.round(Math.abs(wind)));
    let arrow = '';
    for (let i = 0; i < bars; i++) arrow += dir;
    hudWind.textContent = `Wind: ${arrow}`;
  }

  // ─── Main render loop ─────────────────────────────────────────────────────
  function render() {
    if (gameState === 'playing' || gameState === 'paused') {
      ctx.save();
      ctx.translate(shakeOffset.x, shakeOffset.y);

      drawSky();
      drawSun();
      drawBuildings();

      // Previous trail
      drawTrail(previousTrail, 0.25);
      // Current trail
      drawTrail(bananaTrail, 0.5);

      // Gorillas
      drawGorilla(gorillas[0].x, gorillas[0].y, gorillaAnim[0]);
      drawGorilla(gorillas[1].x, gorillas[1].y, gorillaAnim[1]);

      // Banana
      if (showBanana && banana) {
        drawBanana(banana.x, banana.y, banana.frame);
      }

      // Explosions
      drawExplosions();

      ctx.restore();
    } else if (gameState === 'title' || gameState === 'setup' || gameState === 'waiting' || gameState === 'matchOver') {
      // Draw a static backdrop
      drawSky();
      drawSun();
      if (buildings.length > 0) {
        drawBuildings();
        drawGorilla(gorillas[0].x, gorillas[0].y, 0);
        drawGorilla(gorillas[1].x, gorillas[1].y, 0);
      }
    }

    requestAnimationFrame(render);
  }

  // ─── Screen management ────────────────────────────────────────────────────
  function showScreen(id) {
    document.querySelectorAll('.screen').forEach(el => el.classList.remove('active'));
    if (id) {
      document.getElementById(id).classList.add('active');
    }
    // HUD is always visible during play
    if (gameState === 'playing') {
      document.getElementById('hud').classList.add('active');
    }
  }

  function switchToTitle() {
    gameState = 'title';
    showScreen('title-screen');
    // Generate a nice backdrop
    citySeed = (Math.random() * 0xFFFFFFFF) >>> 0;
    buildings = generateCity(citySeed);
    buildTerrainCanvas();
    const rng = mulberry32(citySeed + 12345);
    gorillas = placeGorillasClient(buildings, rng);
    initTwinkles();
  }

  function placeGorillasClient(blds, rng) {
    const mid = Math.floor(blds.length / 2);
    const leftIdx = Math.floor(rng() * mid);
    const rightIdx = mid + Math.floor(rng() * (blds.length - mid));
    function pos(b) {
      return {
        x: Math.floor(b.x + b.w / 2 - GORILLA_W / 2),
        y: b.y - GORILLA_H,
      };
    }
    return [pos(blds[leftIdx]), pos(blds[rightIdx])];
  }

  function switchToSetup() {
    gameState = 'setup';
    showScreen('setup-screen');
    playUIConfirm();
    document.getElementById('player-name').focus();
  }

  function switchToWaiting() {
    gameState = 'waiting';
    showScreen('waiting-screen');
    document.getElementById('waiting-url').textContent = window.location.href;
  }

  function switchToPlaying() {
    gameState = 'playing';
    document.querySelectorAll('.screen').forEach(el => el.classList.remove('active'));
    document.getElementById('hud').classList.add('active');
    updateHUD();
  }

  function switchToMatchOver(winner, finalScores) {
    gameState = 'matchOver';
    const winnerName = winner === 1 ? playerNames[0] : playerNames[1];
    document.getElementById('winner-text').textContent = winnerName + ' WINS!';
    document.getElementById('final-scores').textContent =
      `${playerNames[0]}: ${finalScores[0]}  —  ${playerNames[1]}: ${finalScores[1]}`;
    showScreen('match-over-screen');
  }

  // ─── HUD updates ──────────────────────────────────────────────────────────
  function updateHUD() {
    document.getElementById('hud-p1').textContent = `${playerNames[0]}: ${scores[0]}`;
    document.getElementById('hud-p2').textContent = `${playerNames[1]}: ${scores[1]}`;

    const turnName = currentPlayer === 1 ? playerNames[0] : playerNames[1];
    document.getElementById('hud-turn').textContent = `${turnName}'s turn`;

    drawWindArrow();
    updateInputPanel();
  }

  function updateInputPanel() {
    const panel = document.getElementById('input-panel');
    const isMyTurn = myPlayer === currentPlayer;

    if (isMyTurn && gameState === 'playing' && !showBanana) {
      panel.style.display = 'block';
      document.getElementById('input-angle').focus();
    } else {
      panel.style.display = 'none';
    }
  }

  // ─── Screen shake ──────────────────────────────────────────────────────────
  function startShake() {
    let elapsed = 0;
    const duration = 150;
    if (shakeTimer) clearInterval(shakeTimer);
    shakeTimer = setInterval(() => {
      elapsed += 16;
      if (elapsed > duration) {
        shakeOffset.x = 0;
        shakeOffset.y = 0;
        clearInterval(shakeTimer);
        shakeTimer = null;
        return;
      }
      shakeOffset.x = (Math.random() - 0.5) * 6;
      shakeOffset.y = (Math.random() - 0.5) * 6;
    }, 16);
  }

  // ─── Victory dance ─────────────────────────────────────────────────────────
  function startVictoryDance(winnerIdx) {
    let toggle = true;
    playVictorySound();
    victoryDanceTimer = setInterval(() => {
      gorillaAnim[winnerIdx] = toggle ? 3 : 4;
      toggle = !toggle;
    }, 250); // ~4 Hz
    setTimeout(() => {
      clearInterval(victoryDanceTimer);
      victoryDanceTimer = null;
      gorillaAnim[winnerIdx] = 0;
      stopVictorySound();
    }, 2500);
  }

  // ─── Network message handlers ─────────────────────────────────────────────

  Net.on('_connected', () => {
    switchToWaiting();
    // Send settings — server only accepts from host (player 1)
    Net.send({
      type: 'setSettings',
      rounds: roundsToWin,
      gravity: gravityMultiplier,
      explosionRadius: explosionRadius,
      timeOfDay: timeOfDay,
    });
  });

  Net.on('_disconnected', () => {
    // If in a game, show disconnect screen
    if (gameState === 'playing') {
      document.getElementById('disconnect-screen').classList.add('active');
    }
  });

  Net.on('waiting', (msg) => {
    myPlayer = msg.player;
    switchToWaiting();
    // Update status text based on host/joiner
    const statusEl = document.getElementById('waiting-status');
    if (myPlayer === 1) {
      statusEl.textContent = 'Share the URL above with Player 2';
    } else {
      statusEl.textContent = 'Waiting for host to start the game...';
      // Disable settings fields for non-host
      document.getElementById('rounds-to-win').disabled = true;
      document.getElementById('gravity-select').disabled = true;
      document.getElementById('explosive-select').disabled = true;
      document.getElementById('timeofday-select').disabled = true;
      document.getElementById('setup-host-note').style.display = 'block';
    }
  });

  Net.on('assigned', (msg) => {
    myPlayer = msg.player;
    opponentName = msg.opponentName;
    if (msg.token) sessionToken = msg.token;
    if (myPlayer === 1) {
      playerNames = [myName, opponentName];
    } else {
      playerNames = [opponentName, myName];
    }
    document.getElementById('disconnect-screen').classList.remove('active');
  });

  Net.on('roundStart', (msg) => {
    citySeed = msg.citySeed;
    gorillas = msg.gorillas;
    wind = msg.wind;
    currentPlayer = msg.currentPlayer;
    scores = msg.scores;

    // Apply settings from server
    if (msg.timeOfDay) timeOfDay = msg.timeOfDay;
    if (msg.explosionRadius) explosionRadius = msg.explosionRadius;
    if (msg.gravity) gravityMultiplier = msg.gravity;

    // Generate matching city
    buildings = generateCity(citySeed);
    carvedExplosions = [];
    buildTerrainCanvas();

    // Reset banana state
    banana = null;
    bananaTrail = [];
    previousTrail = [];
    showBanana = false;
    explosions = [];
    gorillaAnim = [0, 0];

    initTwinkles();
    generateStars();
    switchToPlaying();
  });

  Net.on('turn', (msg) => {
    currentPlayer = msg.currentPlayer;
    showBanana = false;
    banana = null;
    previousTrail = [...bananaTrail];
    bananaTrail = [];
    gorillaAnim = [0, 0];
    updateHUD();
  });

  Net.on('throwAnim', (msg) => {
    const idx = msg.player - 1;
    playThrowSound();
    // Show arm raise animation
    if (idx === 0) {
      gorillaAnim[idx] = 1; // right arm for P1
    } else {
      gorillaAnim[idx] = 2; // left arm for P2
    }
    // After brief delay, switch to release
    setTimeout(() => {
      if (idx === 0) {
        gorillaAnim[idx] = 2;
      } else {
        gorillaAnim[idx] = 1;
      }
      setTimeout(() => {
        gorillaAnim[idx] = 0;
      }, 100);
    }, 200);
  });

  Net.on('banana', (msg) => {
    showBanana = true;
    banana = { x: msg.x, y: msg.y, frame: msg.frame };
    bananaTrail.push({ x: msg.x, y: msg.y });

    // Check sun proximity for visual reaction
    const dx = msg.x - SUN_X;
    const dy = msg.y - SUN_Y;
    if (dx * dx + dy * dy <= SUN_RADIUS * SUN_RADIUS && !sunSurprised) {
      sunSurprised = true;
      if (sunSurpriseTimer) clearTimeout(sunSurpriseTimer);
      sunSurpriseTimer = setTimeout(() => {
        sunSurprised = false;
      }, 500);
    }
  });

  Net.on('sunHit', () => {
    playSunHitSound();
    sunSurprised = true;
    if (sunSurpriseTimer) clearTimeout(sunSurpriseTimer);
    sunSurpriseTimer = setTimeout(() => {
      sunSurprised = false;
    }, 500);
  });

  Net.on('explosion', (msg) => {
    showBanana = false;
    banana = null;

    playExplosionSound();

    // Carve terrain
    carvedExplosions.push({ x: msg.x, y: msg.y, radius: msg.radius });
    carveExplosion(msg.x, msg.y, msg.radius);

    // Visual explosion animation
    explosions.push({
      x: msg.x,
      y: msg.y,
      maxRadius: msg.radius,
      progress: 0,
    });
  });

  Net.on('gorillaHit', (msg) => {
    showBanana = false;
    banana = null;
    scores = msg.scores;

    playGorillaHitSound();
    startShake();

    const winnerIdx = msg.winner - 1;
    startVictoryDance(winnerIdx);

    updateHUD();
  });

  Net.on('miss', () => {
    showBanana = false;
    banana = null;
  });

  Net.on('matchOver', (msg) => {
    stopVictorySound();
    switchToMatchOver(msg.winner, msg.finalScores);
  });

  Net.on('opponentDisconnected', () => {
    if (gameState === 'playing') {
      document.getElementById('disconnect-screen').classList.add('active');
    }
  });

  Net.on('opponentReconnected', () => {
    document.getElementById('disconnect-screen').classList.remove('active');
  });

  Net.on('opponentTimedOut', () => {
    document.getElementById('disconnect-screen').classList.remove('active');
    switchToWaiting();
  });

  Net.on('settingsSync', (msg) => {
    roundsToWin = msg.roundsToWin;
    gravityMultiplier = msg.gravity;
    explosionRadius = msg.explosionRadius;
    timeOfDay = msg.timeOfDay;
    // Update setup dropdowns to reflect host's choices (for P2 visibility)
    document.getElementById('rounds-to-win').value = roundsToWin;
    document.getElementById('gravity-select').value = gravityMultiplier;
    document.getElementById('explosive-select').value = explosionRadius;
    document.getElementById('timeofday-select').value = timeOfDay;
  });

  Net.on('error', (msg) => {
    console.warn('Server error:', msg.message);
  });

  // ─── Fire shot helper ──────────────────────────────────────────────────────
  function fireShot() {
    if (gameState !== 'playing') return;
    if (myPlayer !== currentPlayer) return;
    if (showBanana) return;
    const angle = Math.max(0, Math.min(90, parseInt(document.getElementById('input-angle').value) || 0));
    const velocity = Math.max(0, Math.min(200, parseInt(document.getElementById('input-velocity').value) || 0));
    Net.send({ type: 'fire', angle, velocity });
    playUIConfirm();
    document.getElementById('input-panel').style.display = 'none';
  }

  // Wire up the fire button
  document.getElementById('fire-btn').addEventListener('click', fireShot);

  // ─── Input handling ────────────────────────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    // Don't intercept when typing in input fields (except Enter/Escape/Tab)
    const activeEl = document.activeElement;
    const isInput = activeEl && (activeEl.tagName === 'INPUT');

    switch (gameState) {
      case 'title':
        if (e.key === 'Enter') {
          e.preventDefault();
          switchToSetup();
        }
        break;

      case 'setup':
        if (e.key === 'Enter') {
          e.preventDefault();
          myName = document.getElementById('player-name').value.trim() || 'Player';
          roundsToWin = parseInt(document.getElementById('rounds-to-win').value) || 3;
          gravityMultiplier = parseFloat(document.getElementById('gravity-select').value) || 1;
          explosionRadius = parseInt(document.getElementById('explosive-select').value) || 30;
          timeOfDay = document.getElementById('timeofday-select').value || 'day';
          playUIConfirm();
          Net.connect(myName, sessionToken);
        }
        break;

      case 'waiting':
        // Nothing to do
        break;

      case 'playing':
        if (e.key === 'Escape' || e.key === 'p' || e.key === 'P') {
          if (!isInput || e.key === 'Escape') {
            e.preventDefault();
            previousState = gameState;
            gameState = 'paused';
            showScreen('pause-screen');
            document.getElementById('hud').classList.add('active');
          }
        }

        if (e.key === 'r' || e.key === 'R') {
          if (!isInput) {
            showConfirmOverlay();
          }
        }

        // Handle input field navigation
        if (e.key === 'Enter') {
          e.preventDefault();
          if (isInput && activeEl.id === 'input-angle') {
            document.getElementById('input-velocity').focus();
          } else {
            fireShot();
          }
        }

        if (isInput && e.key === 'Tab') {
          e.preventDefault();
          if (activeEl.id === 'input-angle') {
            document.getElementById('input-velocity').focus();
          } else {
            document.getElementById('input-angle').focus();
          }
        }
        break;

      case 'paused':
        if (e.key === 'Escape' || e.key === 'p' || e.key === 'P') {
          e.preventDefault();
          gameState = previousState || 'playing';
          document.getElementById('pause-screen').classList.remove('active');
          if (gameState === 'playing') {
            document.getElementById('hud').classList.add('active');
            updateInputPanel();
          }
        }
        break;

      case 'matchOver':
        if (e.key === 'r' || e.key === 'R') {
          Net.send({ type: 'rematch' });
        }
        if (e.key === 'Escape') {
          Net.disconnect();
          switchToTitle();
        }
        break;
    }
  });

  // ─── Confirm overlay ──────────────────────────────────────────────────────
  function showConfirmOverlay() {
    document.getElementById('confirm-screen').classList.add('active');
  }
  function hideConfirmOverlay() {
    document.getElementById('confirm-screen').classList.remove('active');
  }
  document.getElementById('confirm-yes').addEventListener('click', () => {
    hideConfirmOverlay();
    Net.send({ type: 'rematch' });
  });
  document.getElementById('confirm-no').addEventListener('click', () => {
    hideConfirmOverlay();
  });
  document.addEventListener('keydown', (e) => {
    if (!document.getElementById('confirm-screen').classList.contains('active')) return;
    if (e.key === 'y' || e.key === 'Y') {
      e.preventDefault();
      hideConfirmOverlay();
      Net.send({ type: 'rematch' });
    } else if (e.key === 'n' || e.key === 'N' || e.key === 'Escape') {
      e.preventDefault();
      hideConfirmOverlay();
    }
  });

  // ─── Initialize ────────────────────────────────────────────────────────────
  switchToTitle();
  render();
})();
