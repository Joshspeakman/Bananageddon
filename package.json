{
  "name": "bananageddon",
  "productName": "Bananageddon",
  "version": "1.0.0",
  "description": "A faithful browser recreation of QBasic Gorillas — LAN multiplayer banana-throwing mayhem",
  "main": "electron/main.js",
  "engines": {
    "node": ">=16.17"
  },
  "scripts": {
    "start": "node server.js",
    "test": "node tests/server-regression.js && node tests/syntax-check.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder -lwm"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.joshspeakman.bananageddon",
    "productName": "Bananageddon",
    "copyright": "Copyright © 2025 Josh Speakman",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "shared.js",
      "game.js",
      "background.js",
      "lighting.js",
      "particles.js",
      "net.js",
      "index.html",
      "styles.css",
      "*.mp3",
      "package.json",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/app-builder-lib/**/*",
      "!**/{.git,.idea,.vscode,.claude}",
      "!**/{*.bak,*.md,tests}",
      "!**/*.{ts,map}",
      "!**/.DS_Store"
    ],
    "asar": true,
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "category": "Game",
      "icon": "assets/icon.png",
      "synopsis": "QBasic Gorillas reimagined for LAN multiplayer",
      "description": "Bananageddon is a faithful browser recreation of QBasic Gorillas — LAN multiplayer banana-throwing mayhem with co-op, gauntlet, and team modes."
    },
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bananageddon"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.games",
      "icon": "assets/icon.icns",
      "identity": null
    },
    "dmg": {
      "title": "Bananageddon"
    }
  }
}
