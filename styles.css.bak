/* Monkey Maddness — Styles */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #000;
  overflow: hidden;
  font-family: 'Courier New', monospace;
  color: #fff;
}

#game-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

#gameCanvas {
  image-rendering: pixelated;
  image-rendering: crisp-edges;
}

/* Screen overlays */
.screen {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: none;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  z-index: 10;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.screen.active {
  display: flex;
  pointer-events: auto;
}

/* Title screen */
#title-screen {
  background: rgba(0, 0, 100, 0.85);
}

.title-text {
  font-size: 48px;
  font-weight: bold;
  color: #FFFF55;
  text-shadow: 3px 3px 0 #AA5500;
  margin-bottom: 40px;
  letter-spacing: 4px;
}

.subtitle {
  font-size: 18px;
  color: #AAAAAA;
  animation: blink 1.2s step-end infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* Setup screen */
#setup-screen {
  background: rgba(0, 0, 100, 0.9);
}

.setup-box {
  background: #000055;
  border: 2px solid #5555FF;
  padding: 30px 40px;
  text-align: center;
}

.setup-box h2 {
  color: #FFFF55;
  margin-bottom: 20px;
  font-size: 24px;
}

.setup-field {
  margin: 12px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.setup-field label {
  color: #55FFFF;
  font-size: 14px;
}

.setup-field input,
.setup-field select {
  background: #000022;
  border: 1px solid #5555FF;
  color: #FFFFFF;
  font-family: 'Courier New', monospace;
  font-size: 14px;
  padding: 4px 8px;
  width: 140px;
  outline: none;
}

.setup-field input:focus,
.setup-field select:focus {
  border-color: #FFFF55;
}

.setup-field select option {
  background: #000022;
  color: #FFFFFF;
}

.setup-hint {
  margin-top: 20px;
  color: #AAAAAA;
  font-size: 12px;
}

/* Waiting screen */
#waiting-screen {
  background: rgba(0, 0, 100, 0.9);
}

.waiting-box {
  background: #000055;
  border: 2px solid #5555FF;
  padding: 30px 40px;
  text-align: center;
}

.waiting-box h2 {
  color: #FFFF55;
  margin-bottom: 20px;
}

.waiting-url {
  color: #55FF55;
  font-size: 16px;
  margin: 10px 0;
  padding: 8px;
  background: #000022;
  border: 1px solid #555555;
  user-select: all;
}

.waiting-status {
  color: #AAAAAA;
  font-size: 12px;
  margin-top: 10px;
}

/* HUD */
#hud {
  pointer-events: none;
  z-index: 5;
}

#hud.active {
  pointer-events: none;
}

.hud-score {
  position: absolute;
  top: 8px;
  font-size: 14px;
  color: #FFFFFF;
  background: rgba(0, 0, 0, 0.6);
  padding: 4px 10px;
}

.hud-left {
  left: 8px;
}

.hud-right {
  right: 8px;
}

.hud-turn {
  position: absolute;
  top: 8px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 14px;
  color: #FFFF55;
  background: rgba(0, 0, 0, 0.6);
  padding: 4px 10px;
}

.hud-wind {
  position: absolute;
  bottom: 8px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 12px;
  color: #55FFFF;
  background: rgba(0, 0, 0, 0.6);
  padding: 4px 12px;
}

/* Input panel */
.input-panel {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 80, 0.9);
  border: 2px solid #5555FF;
  padding: 12px 20px;
  pointer-events: auto;
  z-index: 15;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 6px 0;
}

.input-row label {
  color: #55FFFF;
  font-size: 13px;
  width: 70px;
}

.input-row input {
  background: #000022;
  border: 1px solid #5555FF;
  color: #FFFFFF;
  font-family: 'Courier New', monospace;
  font-size: 13px;
  padding: 3px 6px;
  width: 70px;
  outline: none;
}

.input-row input:focus {
  border-color: #FFFF55;
}

.fire-btn {
  display: block;
  width: 100%;
  margin-top: 10px;
  padding: 8px 0;
  background: #AA0000;
  color: #FFFF55;
  border: 2px solid #FF5555;
  font-family: 'Courier New', monospace;
  font-size: 16px;
  font-weight: bold;
  letter-spacing: 2px;
  cursor: pointer;
  text-align: center;
}

.fire-btn:hover {
  background: #CC2200;
  border-color: #FFFF55;
}

.fire-btn:active {
  background: #FF4400;
}

/* Match over */
#match-over-screen {
  background: rgba(0, 0, 0, 0.8);
}

.match-over-box {
  text-align: center;
}

.match-over-box h1 {
  font-size: 36px;
  color: #FFFF55;
  margin-bottom: 16px;
}

#final-scores {
  font-size: 18px;
  color: #FFFFFF;
  margin-bottom: 20px;
}

.match-over-hint {
  color: #AAAAAA;
  font-size: 14px;
}

/* Pause */
#pause-screen {
  background: rgba(0, 0, 0, 0.7);
}

.pause-box {
  text-align: center;
}

.pause-box h2 {
  color: #FFFF55;
  font-size: 32px;
  margin-bottom: 12px;
}

/* Disconnect */
#disconnect-screen {
  background: rgba(0, 0, 0, 0.8);
}

.disconnect-box {
  text-align: center;
  color: #FF5555;
}

.disconnect-box h2 {
  margin-bottom: 12px;
}

/* Confirm overlay */
.confirm-box {
  background: rgba(0, 0, 0, 0.85);
  border: 2px solid #FFAA00;
  padding: 24px 32px;
  text-align: center;
  color: #FFAA00;
}

.confirm-box h2 {
  margin-bottom: 16px;
}

.confirm-buttons {
  display: flex;
  gap: 16px;
  justify-content: center;
}

.confirm-btn {
  font-family: 'Courier New', monospace;
  font-size: 16px;
  padding: 8px 24px;
  background: #333;
  color: #FFAA00;
  border: 2px solid #FFAA00;
  cursor: pointer;
}

.confirm-btn:hover {
  background: #FFAA00;
  color: #000;
}

/* Setup host note */
.setup-host-note {
  margin-top: 8px;
  font-size: 11px;
  color: #FF5555;
  text-align: center;
}
